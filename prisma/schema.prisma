// ============================================================
// CONTENT DNA FINGERPRINTING
// ============================================================

model ContentFingerprint {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentId       String   @unique @map("content_id") @db.Uuid
  content         Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  platform        Platform
  
  // HOOK DNA
  hookType        String   @map("hook_type") // "question", "statistic", "bold_claim", "story_opener", "how_to", "list_number", "controversy", "curiosity_gap"
  hookLength      Int      @map("hook_length")
  hookUsesNumber  Boolean  @default(false) @map("hook_uses_number")
  hookUsesEmoji   Boolean  @default(false) @map("hook_uses_emoji")
  hookUsesYou     Boolean  @default(false) @map("hook_uses_you") // addresses reader directly
  hookEmotionalTone String  @map("hook_emotional_tone") // "surprise", "urgency", "curiosity", "empathy", "authority"
  
  // CONTENT DNA
  topic           String
  subtopic        String?
  angle           String   @map("content_angle") // "educational", "inspirational", "entertaining", "promotional", "behind_scenes"
  structure       String   @map("content_structure") // "tip_list", "story_arc", "problem_solution", "before_after", "myth_bust", "how_to"
  captionLength   Int      @map("caption_length")
  paragraphCount  Int      @map("paragraph_count")
  usesLineBreaks  Boolean  @default(false) @map("uses_line_breaks")
  readabilityLevel String  @map("readability_level") // "simple", "moderate", "complex"
  callToAction    String?  @map("call_to_action") // "save", "comment", "click_link", "follow", "share", "none"
  ctaPlacement    String?  @map("cta_placement") // "end", "middle", "beginning"
  
  // VISUAL DNA
  visualType      String?  @map("visual_type") // "ai_photo", "product_shot", "text_overlay", "carousel", "reel", "infographic"
  visualProvider  String?  @map("visual_provider")
  dominantColor   String?  @map("dominant_color")
  brightness      String?  @map("brightness") // "light", "medium", "dark"
  hasText         Boolean  @default(false) @map("has_text")
  textAmount      String?  @map("text_amount") // "none", "minimal", "moderate", "heavy"
  hasProduct      Boolean  @default(false) @map("has_product")
  hasPerson       Boolean  @default(false) @map("has_person")
  layout          String?  @map("layout") // "centered", "left_aligned", "full_bleed", "split"
  slideCount      Int?     @map("slide_count")
  
  // TIMING DNA
  dayOfWeek       Int      @map("day_of_week") // 0=Sun ... 6=Sat
  hourOfDay       Int      @map("hour_of_day")
  isWeekend       Boolean  @default(false) @map("is_weekend")
  seasonalContext String?  @map("seasonal_context") // "none", "holiday_adjacent", "seasonal_topic", "cultural_moment"
  
  // DISTRIBUTION DNA
  hashtagCount    Int      @map("hashtag_count")
  hashtagMix      String?  @map("hashtag_mix") // "mostly_niche", "mostly_discovery", "balanced", "branded_heavy"
  mentionsCount   Int      @default(0) @map("mentions_count")
  hasLocation     Boolean  @default(false) @map("has_location")
  
  // PERFORMANCE (filled after 7 days)
  engagementRate  Float?   @map("engagement_rate")
  reachRate       Float?   @map("reach_rate")
  saveRate        Float?   @map("save_rate")
  shareRate       Float?   @map("share_rate")
  commentRate     Float?   @map("comment_rate")
  impressions     Int?     @map("impressions")
  reach           Int?     @map("reach")
  likes           Int?     @map("likes")
  comments        Int?     @map("comments")
  shares          Int?     @map("shares")
  saves           Int?     @map("saves")
  clicks          Int?     @map("clicks")
  percentileRank  Float?   @map("percentile_rank")
  
  // Status
  evaluatedAt     DateTime? @map("evaluated_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([organizationId, platform])
  @@index([organizationId, evaluatedAt])
  @@index([organizationId, hookType])
  @@index([organizationId, topic])
  @@index([organizationId, angle])
  @@map("content_fingerprints")
}

// ============================================================
// POST-MORTEM EVALUATION
// ============================================================

model PostMortem {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentId       String   @unique @map("content_id") @db.Uuid
  content         Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  actualPerformance Json    @map("actual_performance")
  agentEvaluations Json    @map("agent_evaluations")
  overallVerdict  String   @map("overall_verdict") // "hit", "miss", "average"
  keyLearnings    String[] @map("key_learnings")
  
  evaluatedAt     DateTime @default(now()) @map("evaluated_at")
  
  @@index([organizationId, evaluatedAt])
  @@index([organizationId, overallVerdict])
  @@map("post_mortems")
}

// ============================================================
// AGENT SCORECARD
// ============================================================

model AgentScorecard {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentName       String   @map("agent_name")
  period          String   // "2026-02", "2026-Q1"
  totalEvaluations Int     @default(0) @map("total_evaluations")
  avgAccuracy     Float    @default(0) @map("avg_accuracy")
  trend           String?  // "improving", "stable", "declining"
  topLessons      String[] @default([]) @map("top_lessons")
  
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@unique([organizationId, agentName, period])
  @@map("agent_scorecards")
}

// ============================================================
// DNA PROFILE
// ============================================================

model DNAProfile {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @unique @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  platform        Platform
  
  // Winning DNA combinations (high performers)
  winningHooks    String[] @default([]) @map("winning_hooks")
  winningTopics   String[] @default([]) @map("winning_topics")
  winningAngles   String[] @default([]) @map("winning_angles")
  winningStructures String[] @default([]) @map("winning_structures")
  winningVisualTypes String[] @default([]) @map("winning_visual_types")
  winningDays     Int[]    @default([]) @map("winning_days")
  winningHours    Int[]    @default([]) @map("winning_hours")
  winningHashtagMix String? @map("winning_hashtag_mix")
  
  // Losing DNA combinations (underperformers)
  losingHooks     String[] @default([]) @map("losing_hooks")
  losingTopics    String[] @default([]) @map("losing_topics")
  losingAngles    String[] @default([]) @map("losing_angles")
  
  // Fatigue scores (avoid over-repetition)
  hookFatigue     Json     @default("{}") @map("hook_fatigue") // { "question": 0.8, ... }
  topicFatigue    Json     @default("{}") @map("topic_fatigue")
  angleFatigue    Json     @default("{}") @map("angle_fatigue")
  
  // Stats
  totalPostsAnalyzed Int    @default(0) @map("total_posts_analyzed")
  hitRate          Float    @default(0) @map("hit_rate")
  avgEngagement    Float    @default(0) @map("avg_engagement")
  
  lastUpdatedAt   DateTime @default(now()) @map("last_updated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@unique([organizationId, platform])
  @@map("dna_profiles")
}

// ============================================================
// GOAL TRACKING
// ============================================================

model Goal {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  type            GoalType
  description     String    @db.Text
  isActive        Boolean   @default(true) @map("is_active")
  priority        Int       @default(1) // 1 = primary goal
  
  // Targets (set by AI based on historical data + industry benchmarks)
  targets         Json      // GoalTargets object
  currentProgress Json?     @map("current_progress") // Latest progress snapshot
  adjustments     Json?     @map("adjustments") // Strategy adjustments made
  
  // Timeline
  startDate       DateTime  @default(now()) @map("start_date")
  targetDate      DateTime? @map("target_date")
  achievedAt      DateTime? @map("achieved_at")
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  checkpoints     GoalCheckpoint[]
  
  @@index([organizationId, isActive])
  @@map("goals")
}

model GoalCheckpoint {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId          String   @map("goal_id") @db.Uuid
  goal            Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")
  
  // Target values for this period
  targetValue     Float    @map("target_value")
  targetUnit      String   @map("target_unit") // "percent", "count", "currency"
  
  // Actual values achieved
  actualValue     Float?   @map("actual_value")
  
  // Progress calculation
  progressPercent Float?   @map("progress_percent")
  onTrack         Boolean? @map("on_track")
  
  // Status
  status          CheckpointStatus @default(PENDING)
  notes           String?  @db.Text
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([goalId, periodStart])
  @@map("goal_checkpoints")
}

enum GoalType {
  grow_followers
  drive_website_traffic
  drive_sales
  increase_engagement
  build_awareness
  generate_leads
  launch_product
  build_community
  improve_brand_perception
  custom
}

enum CheckpointStatus {
  PENDING
  IN_PROGRESS
  ACHIEVED
  MISSED
  ADJUSTED
}

// ============================================================
// NETWORK INTELLIGENCE (Inter-Client Learning)
// ============================================================

model PlatformInsight {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Insight categorization
  industry        String    // "skincare", "food", "tech", etc.
  insightType     InsightType
  platform        Platform?
  
  // The insight itself (anonymized)
  pattern         String    @db.Text // "Carousel posts get 3.2x more engagement"
  supportingData Json?     @map("supporting_data") // Anonymized stats
  
  // Confidence scoring
  confidence      Float     @default(0.5) // 0-1, based on how many clients show this pattern
  evidenceCount   Int       @default(1) @map("evidence_count") // How many clients support this
  lastValidated   DateTime? @map("last_validated")
  
  // Lifecycle
  isActive       Boolean   @default(true) @map("is_active")
  archivedAt     DateTime? @map("archived_at")
  archiveReason  String?   @map("archive_reason")
  
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  
  @@index([industry, insightType])
  @@index([industry, platform])
  @@index([isActive, confidence])
  @@map("platform_insights")
}

enum InsightType {
  content_format     // "carousels outperform static"
  hook_type          // "question hooks work best"
  posting_time      // "Tuesday 9am is best"
  hashtag_strategy  // "niche hashtags outperform mega"
  visual_style      // "minimal text overlays work"
  engagement_tactic // "asking questions drives comments"
  campaign_type     // "product launches work well"
}
// SHARED MEMORY (pgvector)
// ============================================================

model Memory {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Content - the memory text stored as vector
  content         String    @db.Text
  embedding       Unsupported("vector(1536)")? // OpenAI text-embedding-3-small: 1536 dimensions
  
  // Metadata for filtering
  memoryType      String    @map("memory_type") // "content_created", "content_performance", etc.
  agentSource     String    @map("agent_source") // Which agent created this memory
  platform        String?   // Platform if relevant
  contentId       String?   @map("content_id") @db.Uuid // Related content ID if applicable
  
  // Importance scoring
  importance      Float     @default(0.5) // 0-1, higher = more important to recall
  accessCount     Int       @default(0) @map("access_count") // How often this memory has been recalled
  lastAccessedAt  DateTime? @map("last_accessed_at")
  
  // Lifecycle
  expiresAt       DateTime? @map("expires_at") // Some memories are temporary (trends, time-sensitive)
  isConsolidated  Boolean   @default(false) @map("is_consolidated") // Has been merged into a summary memory
  consolidatedInto String?  @map("consolidated_into") @db.Uuid // ID of the summary memory this was merged into
  
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  @@index([organizationId, memoryType])
  @@index([organizationId, createdAt])
  @@index([organizationId, importance])
  @@map("memory")
}

// ============================================================
// BILLING - PLAN DEFINITIONS
// ============================================================

model BillingPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  slug            String   @unique
  description     String?
  isActive        Boolean  @default(true)
  isPublic        Boolean  @default(true)
  sortOrder       Int      @default(0)

  // Trial
  trialDays       Int      @default(14)

  // Limits
  maxPlatforms    Int      // 2, 4, -1 (unlimited)
  maxPostsPerMonth Int     // 40, 80, -1 (unlimited)
  maxBrands       Int      @default(1)
  maxTeamMembers  Int      @default(1)

  // Agent access
  agentTier       String   // "core", "intelligence", "full", "custom"
  enabledAgents   String[] // Explicit list if agentTier is "custom"

  // Feature flags
  features        Json     // { "creative_director": true, "roi_attribution": false, ... }

  // Stripe references
  stripePrices    StripePlanPrice[]

  // Usage-based pricing
  isUsageBased    Boolean  @default(false)
  usageUnitName   String?  // "client", "post", "api_call"
  usageIncluded   Int?     // Included units before overage
  overagePerUnit  Json?    // { "usd": 0.50, "eur": 0.45 } per extra unit

  subscriptions   Subscription[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("billing_plans")
}

model StripePlanPrice {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  billingPlanId   String   @map("billing_plan_id") @db.Uuid
  billingPlan     BillingPlan @relation(fields: [billingPlanId], references: [id], onDelete: Cascade)

  currency        String   // "usd", "eur", "gbp", "brl", "jpy", etc.
  interval        String   // "month", "year"

  // Prices in smallest currency unit (cents, pence, yen, etc.)
  unitAmount      Int      // 19900 = $199.00, 17900 = €179.00

  // Stripe IDs
  stripeProductId String   @map("stripe_product_id")
  stripePriceId   String   @map("stripe_price_id")

  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([billingPlanId, currency, interval])
  @@index([stripePriceId])
  @@map("stripe_plan_prices")
}

// ============================================================
// BILLING - ORGANIZATION SUBSCRIPTIONS
// ============================================================

model Subscription {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String   @unique @map("organization_id") @db.Uuid
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  billingPlanId       String   @map("billing_plan_id") @db.Uuid
  billingPlan         BillingPlan @relation(fields: [billingPlanId], references: [id])

  // Stripe
  stripeCustomerId    String   @unique @map("stripe_customer_id")
  stripeSubscriptionId String  @unique @map("stripe_subscription_id")
  stripePriceId        String   @map("stripe_price_id")
  stripeSubscriptionItemId String? @map("stripe_subscription_item_id")

  // State
  status              String   // "trialing", "active", "past_due", "canceled", "paused", "unpaid"
  currency            String   @default("usd")
  interval            String   @default("month")
  currentPeriodStart  DateTime @map("current_period_start")
  currentPeriodEnd    DateTime @map("current_period_end")

  // Trial
  trialStart          DateTime? @map("trial_start")
  trialEnd            DateTime? @map("trial_end")

  // Cancellation
  cancelAtPeriodEnd   Boolean  @default(false) @map("cancel_at_period_end")
  canceledAt          DateTime? @map("canceled_at")
  cancellationReason  String?  @map("cancellation_reason")

  // Usage
  currentUsage        Int      @default(0) @map("current_usage")

  // Dunning
  failedPaymentCount  Int      @default(0) @map("failed_payment_count")
  lastPaymentFailedAt DateTime? @map("last_payment_failed_at")
  dunningStep         Int      @default(0) // 0=none, 1=first warning, 2=second, 3=final

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ============================================================
// BILLING - EVENTS LOG
// ============================================================

model BillingEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String?  @map("organization_id") @db.Uuid
  organization    Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventType       String   @map("event_type") // "subscription_created", "payment_succeeded", "payment_failed", "plan_changed", "canceled", "trial_ending"
  stripeEventId   String?  @unique @map("stripe_event_id")
  data            Json
  processedAt     DateTime? @map("processed_at")
  createdAt       DateTime @default(now())

  @@index([organizationId, eventType])
  @@index([stripeEventId])
  @@map("billing_events")
}

// ============================================================
// AGENT COST TRACKING (Usage-based)
// ============================================================

model AgentCostEvent {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  agentName       String   @map("agent_name")

  // Token usage
  inputTokens     Int      @default(0) @map("input_tokens")
  outputTokens    Int      @default(0) @map("output_tokens")
  totalTokens     Int      @default(0) @map("total_tokens")

  // Cache tokens (from prompt caching)
  cacheReadTokens  Int      @default(0) @map("cache_read_tokens")
  cacheWriteTokens Int      @default(0) @map("cache_write_tokens")

  // Actual cost from provider (in cents)
  costCents       Float    @default(0) @map("cost_cents")

  // Model used
  model           String?

  // Platform (for engagement agent)
  platform        String?

  // Cache layer tracking
  cacheLayer      String?   @map("cache_layer") // "engagement_dedup" | "prompt_cache" | "template_short_circuit"
  cacheHit        Boolean   @default(false) @map("cache_hit")

  // Context
  contentId       String?  @map("content_id") @db.Uuid
  pipelineRunId    String?  @map("pipeline_run_id") @db.Uuid

  // Timestamp
  period          String   // "2026-02" for monthly aggregation
  createdAt       DateTime @default(now())

  @@index([organizationId, period])
  @@index([organizationId, agentName, period])
  @@index([agentName, cacheHit])
  @@index([createdAt])
  @@map("agent_cost_events")
}

// ============================================================
// ENGAGEMENT TEMPLATES (Layer 3: Template Short-Circuit)
// ============================================================

model EngagementTemplate {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String   @map("organization_id") @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  category        String   // "appreciation", "price_inquiry", "emoji_only", etc.
  platform        String?  // null = all platforms
  triggers        String[] // keywords/patterns that activate this template
  responses       String[] // pool of responses (one is picked randomly for variety)
  isActive        Boolean  @default(true) @map("is_active")
  useCount        Int      @default(0) @map("use_count")
  successRate     Float?   @map("success_rate") // updated by self-evaluation agent
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([organizationId, category])
}
